generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  
  // Exchange info
  exchange          String
  exchangeOrderId   String?
  symbol            String
  
  // Order details
  side              OrderSide
  type              OrderType
  quantity          Decimal
  price             Decimal?
  stopPrice         Decimal?
  
  // Fill info
  status            OrderStatus @default(PENDING)
  filledQuantity    Decimal @default(0)
  avgFillPrice      Decimal?
  commission        Decimal @default(0)
  commissionAsset   String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  executedAt DateTime?
  
  @@map("orders")
  @@index([userId, createdAt])
  @@index([symbol, createdAt])
}

model Position {
  id        String   @id @default(uuid())
  userId    String
  
  // Position details
  symbol    String
  side      PositionSide
  quantity  Decimal
  entryPrice Decimal
  currentPrice Decimal?
  
  // Leverage & margin
  leverage  Int @default(1)
  marginType MarginType @default(ISOLATED)
  
  // Risk management
  stopLoss      Decimal?
  takeProfit    Decimal?
  liquidationPrice Decimal?
  
  // PnL
  unrealizedPnl Decimal @default(0)
  realizedPnl   Decimal @default(0)
  
  // Status
  status    PositionStatus @default(OPEN)
  
  // Timestamps
  openedAt  DateTime @default(now())
  closedAt  DateTime?
  updatedAt DateTime @updatedAt
  
  @@map("positions")
  @@index([userId, status])
  @@index([symbol, status])
}

model Bot {
  id        String   @id @default(uuid())
  userId    String
  
  name      String
  type      BotType
  config    Json
  
  // Status
  status    BotStatus @default(STOPPED)
  
  // Performance
  totalProfit   Decimal @default(0)
  totalTrades   Int @default(0)
  winRate       Decimal?
  
  // Timestamps
  createdAt DateTime @default(now())
  startedAt DateTime?
  stoppedAt DateTime?
  updatedAt DateTime @updatedAt
  
  @@map("bots")
  @@index([userId, status])
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  STOP_LOSS_LIMIT
  TAKE_PROFIT
  TAKE_PROFIT_LIMIT
  TRAILING_STOP
}

enum OrderStatus {
  PENDING
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
  EXPIRED
}

enum PositionSide {
  LONG
  SHORT
}

enum MarginType {
  ISOLATED
  CROSS
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

enum BotType {
  GRID
  DCA
  SCALPING
  SWING
  ARBITRAGE
  REBALANCE
}

enum BotStatus {
  RUNNING
  STOPPED
  PAUSED
  ERROR
}
