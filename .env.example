# ============================================
# QUANTUM HEDGE - Переменные окружения
# ============================================

# Скопируйте этот файл в .env и заполните своими данными
# cp .env.example .env

# ============================================
# 1. БАЗЫ ДАННЫХ
# ============================================

# PostgreSQL - основная база
DATABASE_URL=postgresql://quantum:quantum_dev_password@localhost:5432/quantum_hedge

# TimescaleDB - временные ряды
TIMESCALE_URL=postgresql://quantum:quantum_dev_password@localhost:5433/quantum_timeseries

# Redis - кэш
REDIS_URL=redis://:quantum_redis_password@localhost:6379

# Kafka - очередь сообщений
KAFKA_BROKERS=localhost:9092

# Elasticsearch - логи
ELASTICSEARCH_URL=http://localhost:9200

# ============================================
# 2. БЕЗОПАСНОСТЬ (ОБЯЗАТЕЛЬНО СМЕНИТЬ!)
# ============================================

# JWT секреты - сгенерировать командой: openssl rand -hex 32
JWT_SECRET=ваш-секретный-jwt-ключ-смените-в-продакшене
JWT_REFRESH_SECRET=ваш-refresh-секрет-смените-в-продакшене
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Ключ шифрования API-ключей пользователей
ENCRYPTION_KEY=сгенерируйте-32-символа-через-openssl-rand-hex-32

# ============================================
# 3. BINANCE API (получите на binance.com)
# ============================================

# ВАЖНО! Используйте Testnet для обучения!
# Testnet: https://testnet.binance.vision
# Production: https://www.binance.com

BINANCE_API_KEY=ваш-binance-api-key
BINANCE_API_SECRET=ваш-binance-api-secret

# true = тестовая сеть (без реальных денег)
# false = реальная торговля
BINANCE_TESTNET=true

# ============================================
# 4. TELEGRAM BOT (для уведомлений)
# ============================================

# Создайте бота через @BotFather в Telegram
# Команды: /newbot → введите имя → получите токен
TELEGRAM_BOT_TOKEN=8510965559:AAEFF0Jo6mrory_PZse2zenFWMRclEuRaVg

# Ваш Chat ID для получения уведомлений
# Узнать: открыть бота, нажать /start, скопировать ID из сообщения
TELEGRAM_CHAT_ID=ваш-chat-id

# ============================================
# 5. ВНЕШНИЕ API (опционально)
# ============================================

# CoinGecko - данные о криптовалютах
# Получить: https://www.coingecko.com/en/api
COINGECKO_API_KEY=ваш-coingecko-key

# NewsAPI - новости для AI анализа
# Получить: https://newsapi.org
NEWSAPI_KEY=ваш-newsapi-key

# Twitter API - анализ настроений
# Получить: https://developer.twitter.com
TWITTER_API_KEY=ваш-twitter-key

# ============================================
# 6. КОММУНИКАЦИИ (опционально)
# ============================================

# SendGrid - email уведомления
SENDGRID_API_KEY=ваш-sendgrid-key
FROM_EMAIL=noreply@quantumhedge.ai

# Twilio - SMS уведомления
TWILIO_ACCOUNT_SID=ваш-twilio-sid
TWILIO_AUTH_TOKEN=ваш-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# 7. ФРОНТЕНД
# ============================================

NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_TELEGRAM_BOT_URL=http://localhost:3003

# ============================================
# 8. СРЕДА
# ============================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================
# 9. МОНИТОРИНГ
# ============================================

# Sentry - отслеживание ошибок
SENTRY_DSN=ваш-sentry-dsn

# ============================================
# 10. РИСК-МЕНЕДЖМЕНТ (Защита капитала)
# ============================================

# Максимальный размер одной позиции (% от капитала)
MAX_POSITION_SIZE_PERCENT=10

# Максимальный убыток в день (% от капитала)
MAX_DAILY_LOSS_PERCENT=5

# Максимальное плечо (1 = без плеча)
MAX_LEVERAGE=1

# Обязательный stop-loss на каждой сделке
REQUIRE_STOP_LOSS=true
